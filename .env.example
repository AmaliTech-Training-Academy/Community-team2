# Database Password for RDS
# Get the password from AWS Secrets Manager:
# aws secretsmanager get-secret-value --secret-id communityboard-db-credentials --query SecretString --output text | jq -r .password

DB_PASSWORD=your_rds_password_here

# RDS Endpoint (already configured in docker-compose.yml)
