# Required pipeline mode. Valid values: postgres or csv.
PIPELINE_DATA_SOURCE="postgres/csv"

# ETL runtime toggles. These are false by default in config.yml, so set them explicitly for the full Postgres path.
REPLICA_SYNC_ENABLED=true
STAGGING_DDL_ENABLED=true
WAREHOUSE_ENABLED=true
WAREHOUSE_DDL_ENABLED=true

# Airflow email notification overrides.
AIRFLOW_EMAIL_NOTIFICATIONS_ENABLED=true
AIRFLOW_EMAIL_TO=ops@example.com,data@example.com
AIRFLOW_SMTP_MAIL_FROM=your-email@gmail.com
AIRFLOW_CONN_SMTP_DEFAULT=smtp://your-email%40gmail.com:your-app-password@smtp.gmail.com:587?disable_ssl=true&from_email=your-email%40gmail.com
AIRFLOW_ALERT_WEBHOOK_URL=

# External database endpoints used by the ETL roles.
BACKEND_DB_HOST=your-rds-host
BACKEND_DB_PORT=5432
BACKEND_DB_NAME=communityboard
BACKEND_DB_USER=your-db-user
BACKEND_DB_PASSWORD=change-me

REPLICA_DB_HOST=your-rds-host
REPLICA_DB_PORT=5432
REPLICA_DB_NAME=communityboard
REPLICA_DB_USER=your-db-user
REPLICA_DB_PASSWORD=change-me

ANALYTICS_DB_HOST=your-rds-host
ANALYTICS_DB_PORT=5432
ANALYTICS_DB_NAME=communityboard
ANALYTICS_DB_USER=your-db-user
ANALYTICS_DB_PASSWORD=change-me
