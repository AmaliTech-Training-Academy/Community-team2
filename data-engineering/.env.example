# Direct local runtime defaults
PIPELINE_DATA_SOURCE=csv
REPLICA_SYNC_ENABLED=false
STAGGING_DDL_ENABLED=false
WAREHOUSE_ENABLED=false
WAREHOUSE_DDL_ENABLED=false
STAGGING_SOURCE_SCHEMA=replica_raw
WAREHOUSE_SCHEMA=analytics

# Airflow local container runtime
AIRFLOW_UID=50000
AIRFLOW_IMAGE_NAME=community-airflow:local
AIRFLOW_EXECUTOR=LocalExecutor
AIRFLOW_LOAD_EXAMPLES=false
AIRFLOW_DAGS_FOLDER=/opt/airflow/data-engineering/dags
AIRFLOW_DEFAULT_TIMEZONE=UTC
AIRFLOW_WEBSERVER_EXPOSE_CONFIG=false
AIRFLOW_SCHEDULER_ENABLE_HEALTH_CHECK=true
AIRFLOW_PIPELINE_DATA_SOURCE=postgres
AIRFLOW_REPLICA_SYNC_ENABLED=true
AIRFLOW_STAGGING_DDL_ENABLED=true
AIRFLOW_WAREHOUSE_ENABLED=true
AIRFLOW_WAREHOUSE_DDL_ENABLED=true
AIRFLOW_STAGGING_SOURCE_SCHEMA=replica_raw
AIRFLOW_WAREHOUSE_SCHEMA=analytics
AIRFLOW_WEBSERVER_PORT=8088
AIRFLOW_ADMIN_ROLE=Admin
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=change-me
AIRFLOW_ADMIN_FIRSTNAME=Community
AIRFLOW_ADMIN_LASTNAME=Team
AIRFLOW_ADMIN_EMAIL=airflow@example.com

# Airflow metadata database used by the Airflow services.
AIRFLOW_METADATA_DB_HOST=airflow-postgres
AIRFLOW_METADATA_DB_PORT=5432
AIRFLOW_METADATA_DB_NAME=airflow
AIRFLOW_METADATA_DB_USER=airflow
AIRFLOW_METADATA_DB_PASSWORD=change-me

# Airflow notifications
AIRFLOW_MONITORING_ENABLED=true
AIRFLOW_EMAIL_NOTIFICATIONS_ENABLED=false
AIRFLOW_EMAIL_TO=ops@example.com,data@example.com
AIRFLOW_EMAIL_NOTIFY_ON_FAILURE=true
AIRFLOW_EMAIL_NOTIFY_ON_RETRY=true
AIRFLOW_EMAIL_NOTIFY_ON_SUCCESS=false
AIRFLOW_EMAIL_SUBJECT_PREFIX=[community-etl]
AIRFLOW_ALERT_WEBHOOK_URL=

# External RDS host shared by backend source, replica/staging schema, and analytics schema.
BACKEND_DB_HOST=your-rds-host
BACKEND_DB_PORT=5432
BACKEND_DB_NAME=communityboard
BACKEND_DB_USER=your-db-user
BACKEND_DB_PASSWORD=change-me

REPLICA_DB_HOST=your-rds-host
REPLICA_DB_PORT=5432
REPLICA_DB_NAME=communityboard
REPLICA_DB_USER=your-db-user
REPLICA_DB_PASSWORD=change-me

ANALYTICS_DB_HOST=your-rds-host
ANALYTICS_DB_PORT=5432
ANALYTICS_DB_NAME=communityboard
ANALYTICS_DB_USER=your-db-user
ANALYTICS_DB_PASSWORD=change-me
